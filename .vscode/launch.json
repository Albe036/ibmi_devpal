{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run IBM i DevPal",
            "autoAttachChildProcesses": true,
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}",
                "--disable-extensions" 
            ],
            "outFiles": [
                "${workspaceFolder}/out/**/*.js"
            ],
            "sourceMaps": true
        }
    ]
}