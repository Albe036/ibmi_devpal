{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run IBM i DevPal",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}"
            ],
            "outFiles": [
                "${workspaceFolder}/out/**/*.js"
            ],
            "stopOnEntry": false,
            "sourceMaps": true,
            "smartStep": true
        }
    ]
}