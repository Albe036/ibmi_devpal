{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "RPGLE Free-Form",
	"scopeName": "source.rpgle",
	"patterns": [
		{
			"name": "comment.line.double-slash.rpgle",
			"match": "//.*$"
		},
		{
			"name": "keyword.control.rpgle",
			"match": "\\b(?i)(if|else|elseif|endif|for|to|by|endfor|dow|dou|enddo|select|when|other|endsl|begsr|endsr|exsr)\\b"
		},
		{
			"name": "keyword.declaration.rpgle",
			"match": "\\b(?i)(dcl-s|dcl-ds|end-ds|dcl-pr|end-pr|dcl-proc|end-proc|dcl-pi|end-pi|dcl-f|ctl-opt)\\b"
		},
		{
			"name": "variable.language.rpgle",
			"match": "\\b(?i)(\\*inlr|\\*on|\\*off|\\*all|\\*iso|\\*hival|\\*loval)\\b"
		},
		{
			"name": "string.quoted.single.rpgle",
			"begin": "'",
			"end": "'",
			"patterns": [
				{ "match": "''", "name": "constant.character.escape.rpgle" }
			]
		},
		{
			"name": "support.function.built-in.rpgle",
			"match": "%(?i)(trim|subst|scan|replace|found|eof|equal|len|char|int|date|diff|rem|dec)\\b"
		},
		{
			"name": "constant.numeric.rpgle",
			"match": "\\b[0-9]+(\\.[0-9]+)?\\b"
		}
	]
}