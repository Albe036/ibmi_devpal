{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "IBM i Control Language",
	"scopeName": "source.cl",
	"patterns": [
		{
			"name": "comment.block.cl",
			"begin": "/\\*",
			"end": "\\*/"
		},
		{
			"name": "keyword.control.cl",
			"match": "\\b(?i)(PGM|ENDPGM|DCL|DCLF|CHGVAR|IF|THEN|ELSE|DO|ENDDO|GOTO|SELECT|WHEN|OTHERWISE|ENDSELECT|CALL|SUBR|ENDSUBR|RTNSUBR)\\b"
		},
		{
			"name": "variable.other.cl",
			"match": "&[a-zA-Z][a-zA-Z0-9_]*"
		},
		{
			"name": "string.quoted.single.cl",
			"begin": "'",
			"end": "'"
		},
		{
			"name": "entity.name.function.cl",
			"match": "\\b(?i)[A-Z][A-Z0-9]{2,9}\\b",
			"comment": "Esto captura comandos estándar como WRKSPLF, CPYF, etc."
		},
		{
			"name": "constant.language.cl",
			"match": "\\b\\*[A-Z]+\\b",
			"comment": "Valores especiales como *LIBL, *ALL, *YES, *NO"
		}
	]
}